model Payment {
  id              String          @id @default(uuid())
  transactionId   String          @unique
  amount          Float
  method          String          // e.g. "card", "mobile_banking"
  provider        PaymentProvider
  status          PaymentStatus   @default(PENDING)

  providerRef     String?         // Stripe paymentIntentId or SSLCommerz val_id
  paidAt          DateTime?

  rentalRequestId String          @unique
  rentalRequest   RentalRequest   @relation(fields: [rentalRequestId], references: [id])

  tenantId        String
  tenant          User            @relation("TenantPayments", fields: [tenantId], references: [id])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("payments")
}